<% layout('layouts/boilerplate') %>

<div class="home">

  <!-- NAVBAR SPACING -->
  <div class="overlay"></div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <h1>Explore the World 🌍</h1>
      <p>Discover unique places to stay and unforgettable experiences</p>

      <!-- Search Bar -->
      <div class="search-box">
        <input type="text" placeholder="Search destinations..." />
        <button>Search</button>
      </div>

      <a href="/listings" class="cta-btn">Explore Listings</a>
    </div>
  </section>

  <!-- FEATURED SECTION -->
  <section class="featured">
    <h2>Featured Listings</h2>
    <div class="cards">

      <div class="card">
        <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688" />
        <h3>Beach House</h3>
      </div>

      <div class="card">
        <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267" />
        <h3>Modern Apartment</h3>
      </div>

      <div class="card">
        <img src="https://images.unsplash.com/photo-1505691723518-36a5ac3be353" />
        <h3>Luxury Villa</h3>
      </div>

    </div>
  </section>

</div>

<style>
/* RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* HERO */
.hero {
  height: 100vh;
  background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.6)),
    url("https://images.unsplash.com/photo-1507525428034-b723cf961d3e") no-repeat center/cover;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.hero-content {
  color: white;
}

.hero h1 {
  font-size: 3.5rem;
  margin-bottom: 10px;
}

.hero p {
  margin-bottom: 20px;
  font-size: 1.2rem;
}

/* SEARCH BOX */
.search-box {
  display: flex;
  justify-content: center;
  margin-bottom: 20px;
}

.search-box input {
  padding: 12px;
  width: 250px;
  border: none;
  outline: none;
  border-radius: 5px 0 0 5px;
}

.search-box button {
  padding: 12px 20px;
  border: none;
  background: #ff385c;
  color: white;
  border-radius: 0 5px 5px 0;
  cursor: pointer;
}

/* CTA */
.cta-btn {
  display: inline-block;
  padding: 12px 25px;
  background: #ff385c;
  color: white;
  text-decoration: none;
  border-radius: 8px;
  font-weight: bold;
  transition: 0.3s;
}

.cta-btn:hover {
  background: #e03150;
}

/* FEATURED */
.featured {
  padding: 60px 20px;
  text-align: center;
}

.featured h2 {
  margin-bottom: 30px;
  font-size: 2rem;
}

.cards {
  display: flex;
  gap: 20px;
  justify-content: center;
}

.card {
  width: 250px;
  border-radius: 10px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 5px 20px rgba(0,0,0,0.1);
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-5px);
}

.card img {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

.card h3 {
  padding: 10px;
}
</style>