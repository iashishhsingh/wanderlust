<style>
/* NAVBAR */
.navbar {
  backdrop-filter: blur(12px);
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 2px 20px rgba(0,0,0,0.08);
  padding: 0.7rem 1.5rem;
}

/* LOGO */
.navbar-brand {
  font-size: 1.6rem;
  color: #fe424d !important;
  font-weight: bold;
}

.navbar-brand i {
  font-size: 1.8rem;
}

/* NAV LINKS */
.nav-link {
  font-weight: 500;
  color: #333 !important;
  transition: 0.3s;
}

.nav-link:hover {
  color: #fe424d !important;
}

/* SEARCH BAR */
.search-inp {
  border-radius: 50px;
  padding: 0.6rem 1rem;
  border: 1px solid #ddd;
  width: 260px;
  transition: 0.3s;
}

.search-inp:focus {
  box-shadow: 0 0 0 2px rgba(254, 66, 77, 0.2);
  border-color: #fe424d;
}

/* SEARCH BUTTON */
.search-btn {
  background-color: #fe424d;
  color: #fff;
  border-radius: 50px;
  padding: 0.5rem 1.2rem;
  border: none;
  transition: 0.3s;
}

.search-btn:hover {
  background-color: #e03150;
  transform: scale(1.05);
}

/* RIGHT LINKS */
.navbar-nav:last-child .nav-link {
  margin-left: 10px;
  border-radius: 20px;
  padding: 5px 12px;
}

.navbar-nav:last-child .nav-link:hover {
  background-color: rgba(254,66,77,0.1);
}

/* MOBILE */
@media (max-width: 768px) {
  .search-inp {
    width: 100%;
    margin-bottom: 10px;
  }
}
</style>

<nav class="navbar navbar-expand-md sticky-top">
  <div class="container-fluid">

    <!-- LOGO -->
    <a class="navbar-brand" href="/">
      <i class="fa-regular fa-compass"></i> Wanderlust
    </a>

    <!-- TOGGLE -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- NAV CONTENT -->
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

      <!-- LEFT -->
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- CENTER SEARCH -->
      <div class="navbar-nav mx-auto">
        <form class="d-flex align-items-center" action="/listings" method="GET">
          <input
            class="form-control search-inp"
            type="search"
            name="search"
            placeholder="Search destinations..."
          />
          <button class="btn search-btn ms-2" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>
        </form>
      </div>

      <!-- RIGHT -->
      <div class="navbar-nav">
        <a class="nav-link" href="/users/listings/new">Add Listing</a>

        <% if(!currUser) { %>
          <a class="nav-link" href="/users/signup"><b>Sign up</b></a>
          <a class="nav-link" href="/users/login"><b>Log in</b></a>
        <% } else { %>
          <a class="nav-link" href="/users/logout"><b>Log out</b></a>
        <% } %>
      </div>

    </div>
  </div>
</nav>