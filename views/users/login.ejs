<% layout("/layouts/boilerplate") -%>

<body>
        <div class="row mt-4 ">
            <div class="col-6 offset-3">
                 <form action="/login" method="post" novalidate class="needs-validation">
                        <h2>Login</h2>
                        <br>
                        <div class="mb-3" >
                            <label for="username" class="form-label">Username : </label>
                            <input type="text" id="username" name="username" placeholder="Enter username"  class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password : </label>
                            <input type="password" name="password" id="password" placeholder="Enter password"  class="form-control" required>
                        </div>
                        <button class="btn btn-success mt-2">Login</button>            
                    
            </div>
        </div>
        